# =========================================================================
# 🌟 BOMB CRYPTO MARKETPLACE - OPEN SOURCE ENVIRONMENT
# =========================================================================
# Welcome, Contributor!
#
# To get started locally without setting up a full database:
# 1. Copy this file to `.env.development`
# 2. Run `pnpm dev`
#
# By default, the Pulse Dashboards will use this VITE_API_BASE_URL to fetch
# live read-only data from the production network, allowing you to build and
# test the UI instantly!
# =========================================================================

# Note: Since the real live API strictly checks CORS, we use the local proxy
# set up in vite.config.ts for the VITE_API_BASE_URL during development
# so requests go through `http://localhost:3004/pulse-api/bsc` safely!

# The base URL for the Pulse Dashboards API Client
# Valid options:
#  - /pulse-api/bsc      (Uses Vite proxy for Binance Smart Chain)
#  - /pulse-api/polygon  (Uses Vite proxy for Polygon Network)
#  - http://localhost:3003 (If running the backend locally)
VITE_API_BASE_URL=/pulse-api/bsc

# Feature flags and configuration
# VITE_IS_PROD: Set to "true" to enable production mode optimizations
VITE_IS_PROD=false

# VITE_USE_LOCAL: Set to "true" to force API calls to local endpoints
VITE_USE_LOCAL=false

# VITE_USE_NEW_BACKEND: Controls whether to route requests to the modernized backend architecture
VITE_USE_NEW_BACKEND=false
